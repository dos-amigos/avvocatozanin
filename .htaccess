# Kirby .htaccess

# rewrite rules
<IfModule mod_rewrite.c>

# enable awesome urls. i.e.:
# http://yourdomain.com/about-us/team
RewriteEngine on

# Force HTTPS
RewriteCond %{HTTPS} off
RewriteRule ^ https://%{HTTP_HOST}%{REQUEST_URI} [L,R=301]

# make sure to set the RewriteBase correctly
# if you are running the site in a subfolder;
# otherwise links or the entire site will break.
#
# If your homepage is http://yourdomain.com, set:
# RewriteBase /
#
# If your homepage is http://yourdomain.com/mysite, set:
# RewriteBase /mysite

RewriteBase /

# block files and folders beginning with a dot
RewriteRule (^\.|/\.) - [L,F]

# block text files in the content folder from being accessed directly
RewriteRule ^content/(.*)\.(txt|md|mdown)$ index.php [L]

# block all files in the site folder from being accessed directly
# except for requests to plugin assets
RewriteCond %{REQUEST_URI} !^/site/plugins/([^/]+)/assets
RewriteRule ^site/(.*) index.php [L]

# block all files in the kirby folder from being accessed directly
RewriteRule ^kirby/(.*) index.php [L]

# don't redirect direct requests to assets, media and the panel
RewriteCond %{REQUEST_URI} !^/assets
RewriteCond %{REQUEST_URI} !^/media
RewriteCond %{REQUEST_URI} !^/panel

# redirect everything else to the index file
RewriteCond %{REQUEST_FILENAME} !-f
RewriteCond %{REQUEST_FILENAME} !-d
RewriteRule ^(.*) index.php [L]

</IfModule>

# compress text file responses
<IfModule mod_deflate.c>
AddOutputFilterByType DEFLATE text/plain
AddOutputFilterByType DEFLATE text/html
AddOutputFilterByType DEFLATE text/css
AddOutputFilterByType DEFLATE text/javascript
AddOutputFilterByType DEFLATE application/json
AddOutputFilterByType DEFLATE application/javascript
AddOutputFilterByType DEFLATE application/x-javascript
</IfModule>

# set security headers
<IfModule mod_headers.c>
Header set X-Content-Type-Options "nosniff"
</IfModule>

# disable directory indexes
Options -Indexes
